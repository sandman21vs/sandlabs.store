# Opcional. Deixe ADMIN_PASSWORD vazio para usar o setup inicial em /admin/setup.
SECRET_KEY=change-me-to-a-random-string
DATABASE_PATH=/app/data/sandlabs.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Defaults de bootstrap. Depois de salvos em /admin/settings, os valores do banco
# passam a ter prioridade sobre o .env durante o runtime.
COINOS_API_KEY=
COINOS_WEBHOOK_SECRET=
COINOS_ENABLED=0
